"""
Interfaz de Telegram para OpenClaw.

Proporciona:
- Handlers asincrónicos para la aplicación de Telegram PTB (v21+)
- Interfaz sincrónica dispatch_command() para CLI
- Stubs para polling y actualizaciones
"""
from __future__ import annotations

import asyncio
import json
import logging
import os
import sys
from datetime import UTC, datetime
from pathlib import Path
from typing import Any

# Librería de Telegram (PTB v21+)
try:
    from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup, constants
from telegram.ext import (
    ApplicationBuilder,
    CommandHandler,
    MessageHandler,
    CallbackQueryHandler,
    ContextTypes,
    filters,
)

# Componentes OpenClaw
from .audio_engine import download_telegram_file, synthesize_speech, transcribe_audio
from .contracts import TaskEnvelope
from .storage import OpenClawStore
from .session_layer import process_channel_text
from .orchestrator import Orchestrator, CommunicationChannel
