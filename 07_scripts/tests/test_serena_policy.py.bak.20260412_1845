class TestSerenaPolicy(unittest.TestCase):
    def test_classify_write_scope(self):
        with tempfile.TemporaryDirectory() as tmp_dir:
            repo = Path(tmp_dir)
            minimal_repo(repo)
            protected = repo / "docs" / "protegido.md"
            protected.parent.mkdir(parents=True, exist_ok=True)
            protected.write_text("<!-- SISTEMA_TESIS:PROTEGIDO -->\ntexto\n", encoding="utf-8")

            self.assertEqual(classify_write_scope("06_dashboard/generado/demo.md", repo), "derived")
            self.assertEqual(classify_write_scope("docs/protegido.md", repo), "protected")
            self.assertEqual(classify_write_scope("07_scripts/demo.py", repo), "controlled")
            self.assertEqual(classify_write_scope("tmp/demo.txt", repo), "blocked")

    def test_validate_step_and_source(self):
        with tempfile.TemporaryDirectory() as tmp_dir:
            repo = Path(tmp_dir)
            minimal_repo(repo)
            self.assertEqual(
                validate_step_and_source(step_id="VAL-STEP-660", source_event_id="EVT-0001", root=repo),
                [],
            )
            self.assertTrue(
                validate_step_and_source(step_id="VAL-STEP-660", source_event_id="", root=repo)
            )

    def test_preflight_blocks_protected_without_step(self):
        with tempfile.TemporaryDirectory() as tmp_dir:
            repo = Path(tmp_dir)
            minimal_repo(repo)
            protected = repo / "docs" / "protegido.md"
            protected.parent.mkdir(parents=True, exist_ok=True)
            protected.write_text("<!-- SISTEMA_TESIS:PROTEGIDO -->\ntexto\n", encoding="utf-8")

            result = preflight(
                tool_name="canon.apply_controlled_change",
                target_paths=["docs/protegido.md"],
                root=repo,
            )
            self.assertEqual(result["status"], "blocked")

    def test_apply_controlled_change_creates_backup(self):
        with tempfile.TemporaryDirectory() as tmp_dir:
            repo = Path(tmp_dir)
            minimal_repo(repo)
            target = repo / "00_sistema_tesis" / "config" / "demo.json"
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text('{"ok": false}\n', encoding="utf-8")

            result = apply_controlled_change(
                path="00_sistema_tesis/config/demo.json",
                new_content='{"ok": true}\n',
                step_id="VAL-STEP-660",
                source_event_id="EVT-0001",
                intent="Actualizar configuración de prueba",
                root=repo,
            )

            self.assertEqual(result["path"], "00_sistema_tesis/config/demo.json")
            backup_dir = repo / "config" / "backups"
            self.assertTrue(any(backup_dir.iterdir()))

    def test_apply_controlled_change_uses_incremental_manifest_update(self):
        with tempfile.TemporaryDirectory() as tmp_dir:
            repo = Path(tmp_dir)
            minimal_repo(repo)
            target = repo / "00_sistema_tesis" / "config" / "demo.json"
            target.parent.mkdir(parents=True, exist_ok=True)
            target.write_text('{"ok": false}\n', encoding="utf-8")

            with mock.patch("serena_core.update_manifest_for_path") as incremental:
                apply_controlled_change(
                    path="00_sistema_tesis/config/demo.json",
                    new_content='{"ok": true}\n',
                    step_id="VAL-STEP-660",
                    source_event_id="EVT-0001",
                    intent="Actualizar configuración de prueba",
                    root=repo,
                )

            incremental.assert_called_once_with("00_sistema_tesis/config/demo.json", repo)


