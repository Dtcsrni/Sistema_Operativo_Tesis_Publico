{
  "servers": {
    "serena-local": {
      "type": "http",
      "url": "http://127.0.0.1:8765/mcp",
      "env": {
        "SERENA_MCP_DEBUG_LOG": "${workspaceFolder}/historial interno no público/serena_mcp_debug.log",
        "SISTEMA_TESIS_ROOT": "${workspaceFolder}",
        "SISTEMA_TESIS_MCP_HOST_KIND": "vscode"
      },
      "dev": {
        "watch": [
          ".vscode/mcp.json",
          ".vscode/tasks.json",
          ".vscode/serena-http.cmd",
          ".vscode/serena-local-py.cmd",
          "07_scripts/**/*.py",
          "00_sistema_tesis/config/**/*.json",
          "00_sistema_tesis/config/**/*.yaml",
          "00_sistema_tesis/documentacion_sistema/**/*.md",
          "docs/**/*.md"
        ]
      }
    }
  }
}
