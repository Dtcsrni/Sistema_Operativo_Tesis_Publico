# Configuración del Sistema Operativo de Tesis
# Copia este archivo como .env y ajusta los valores

# Nivel de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Ruta al ejecutable de Python si es distinto al del path/activado
# PYTHON_EXEC=V:\Sistema_Operativo_Tesis_Posgrado\.venv\bin\python.exe

# Token de GitHub (opcional, para automatizar pushes desde scripts)
# GITHUB_PAT=ghp_...
