{
  "agents": {
    "defaults": {
      "maxConcurrent": 1,
      "model": {
        "primary": "llamacpp/mistral-nemo:12b",
        "fallbacks": [
          "llamacpp/qwen2.5-coder:7b",
          "llamacpp/gemma3:4b",
          "openrouter/openrouter/free"
        ]
      },
      "embeddedHarness": {
        "runtime": "auto",
        "fallback": "none"
      },
      "workspace": "/var/lib/herramientas/openclaw/workspace"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "llamacpp": {
        "api": "openai-compatible",
        "baseUrl": "http://inferencia-llamacpp:8080/v1",
        "models": [
          {
            "id": "mistral-nemo:12b",
            "name": "mistral-nemo:12b llama.cpp local",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 8192,
            "contextTokens": 8192,
            "maxTokens": 4096,
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0}
          },
          {
            "id": "qwen2.5-coder:7b",
            "name": "qwen2.5-coder:7b llama.cpp local",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 32768,
            "contextTokens": 8192,
            "maxTokens": 4096,
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0}
          }
        ]
      },
      "openrouter": {
        "api": "openai-compatible",
        "baseUrl": "https://openrouter.ai/api/v1",
        "manualApproval": true,
        "freeTier": {
          "requestsPerMinute": 20,
          "dailyWithout10UsdCredits": 50,
          "dailyWith10UsdCredits": 1000
        },
        "models": [
          {
            "id": "openrouter/free",
            "name": "OpenRouter free router (manual, non-sensitive only)",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 131072,
            "contextTokens": 8192,
            "maxTokens": 2048,
            "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0}
          }
        ]
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "allowlist",
      "allowFrom": []
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": 18789
  },
  "tools": {
    "deny": []
  }
}
