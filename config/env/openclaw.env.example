OPENCLAW_TELEGRAM_EDGE_MODEL=qwen3:4b
OPENCLAW_TELEGRAM_FALLBACK_MODEL=qwen3:4b
OPENCLAW_TELEGRAM_POLL_TIMEOUT_SECONDS=20
OPENCLAW_TELEGRAM_POLL_INTERVAL_SECONDS=2
OPENCLAW_TELEGRAM_POLL_LIMIT=10
OPENCLAW_TELEGRAM_MAX_WORKERS=2
# Matrix queda latente por defecto.
OPENCLAW_MATRIX_ENABLED=0
OPENCLAW_MATRIX_HOMESERVER=http://127.0.0.1:6167
OPENCLAW_MATRIX_ACCESS_TOKEN=
OPENCLAW_MATRIX_USER_ID=@openclaw:tesis-edge.local
