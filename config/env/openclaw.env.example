OPENCLAW_GEMINI_API_KEY=
OPENCLAW_GEMINI_TIMEOUT=90
OPENCLAW_WEB_SESSION_REPORTED_MODEL=
OPENCLAW_TELEGRAM_STT_PROVIDER=openai
OPENCLAW_TELEGRAM_STT_MODEL=gpt-4o-mini-transcribe
OPENCLAW_TELEGRAM_TTS_PROVIDER=openai
OPENCLAW_TELEGRAM_TTS_MODEL=gpt-4o-mini-tts
