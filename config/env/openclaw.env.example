OPENCLAW_MATRIX_READY_ROOM_ID=
OPENCLAW_MATRIX_POLL_TIMEOUT_MS=15000
OPENCLAW_MATRIX_POLL_INTERVAL_SECONDS=2
OPENCLAW_MATRIX_READY_ON_START=0
