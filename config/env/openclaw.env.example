OPENCLAW_PORT=18789
OPENCLAW_HOST=127.0.0.1
OPENCLAW_RUNTIME=docker
OPENCLAW_AUTH_MODE=token
OPENCLAW_AUTH_TOKEN=
OPENCLAW_DATA_DIR=/var/lib/herramientas/openclaw
OPENCLAW_CACHE_DIR=/var/cache/herramientas/openclaw
OPENCLAW_LOG_DIR=/var/log/openclaw
OPENCLAW_DB_PATH=/var/lib/herramientas/openclaw/openclaw.db
OPENCLAW_REPO_ROOT=/srv/tesis/repo
OPENCLAW_PYTHON_BIN=/opt/tesis-os/venvs/openclaw/bin/python
OPENCLAW_DOMAINS_ENV_DIR=/etc/tesis-os/domains
OPENCLAW_WEB_ENABLED=1
OPENCLAW_CHATGPT_PLUS_ENABLED=1
OPENCLAW_WEB_SESSION_URL=https://chatgpt.com/
OPENCLAW_WEB_SESSION_USER_DATA_DIR=/var/lib/herramientas/openclaw/web_session_profile
OPENCLAW_WEB_SESSION_CHROMIUM_PATH=/usr/bin/chromium
OPENCLAW_WEB_SESSION_HEADLESS=1
OPENCLAW_WEB_SESSION_LOGIN_TIMEOUT_SECONDS=900
PLAYWRIGHT_BROWSERS_PATH=/var/lib/herramientas/openclaw/ms-playwright
OPENCLAW_ENV_FILE=/etc/tesis-os/openclaw.env
OPENCLAW_SERENA_ENABLED=1
OPENCLAW_SERENA_MODE=auto
OPENCLAW_SERENA_TRANSPORT=http
OPENCLAW_SERENA_URL=http://127.0.0.1:8765/mcp
OPENCLAW_SERENA_TIMEOUT_MS=4000
OPENCLAW_SERENA_AUTO_START=1
OPENCLAW_CLOUD_ENABLED=0
OPENCLAW_PROVIDER_POLICY=hybrid_controlled
OPENCLAW_PREMIUM_AUTO=1
OPENCLAW_DESKTOP_COMPUTE_ENABLED=1
OPENCLAW_DESKTOP_COMPUTE_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_DESKTOP_COMPUTE_AUTH_MODE=none
OPENCLAW_DESKTOP_COMPUTE_AUTH_TOKEN=
OPENCLAW_DESKTOP_COMPUTE_MODEL=mistral-nemo:12b
OPENCLAW_DESKTOP_RUNTIME=llamacpp
OPENCLAW_DESKTOP_RUNTIME_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_DESKTOP_RUNTIME_MODEL=mistral-nemo:12b
# llama.cpp local es la ruta soberana para contexto privado/sensible.
# OpenRouter es remoto y requiere aprobacion manual por tarea.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FREE_RPM=20
OPENROUTER_FREE_DAILY_WITHOUT_10USD_CREDITS=50
OPENROUTER_FREE_DAILY_WITH_10USD_CREDITS=1000
OPENCLAW_DESKTOP_NATIVE_HOST=windows
OPENCLAW_DESKTOP_TUNNEL_LOCAL_BIND=
OPENCLAW_IMAGE_BACKEND=disabled
OPENCLAW_EDGE_ROLE=relay_light_runtime
OPENCLAW_OFFICIAL_GATEWAY_ENABLED=0
OPENCLAW_OFFICIAL_CONFIG_TEMPLATE=/srv/tesis/repo/config/openclaw/openclaw.official.template.json
OPENCLAW_EDGE_INFERENCE_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_RKLLM_ROOT=/opt/tesis-os/vendor/rknn-llm
OPENCLAW_NPU_AUTO_PROMOTE=0
OPENCLAW_NPU_BENCH_CMD=
OPENCLAW_LLAMACPP_LOCAL_FALLBACK=0
OPENCLAW_MAESTRO_ENABLED=0
OPENCLAW_MAESTRO_SESSION_TTL=3600
OPENCLAW_MAESTRO_CHAT_FAST_P95_MS=12000
OPENCLAW_MAESTRO_TECH_P95_MS=30000
OPENCLAW_MAESTRO_RESEARCH_P95_MS=90000
OPENCLAW_MAESTRO_EDGE_OPS_P95_MS=15000
OPENCLAW_TELEGRAM_ENABLED=1
OPENCLAW_TELEGRAM_TOKEN=
OPENCLAW_TELEGRAM_BOT_TOKEN=
OPENCLAW_TELEGRAM_CHAT_ID=
OPENCLAW_TELEGRAM_TIMEOUT_SECONDS=10
OPENCLAW_TELEGRAM_CHAT_PROVIDER=web_session
OPENCLAW_TELEGRAM_CHAT_MODEL=
OPENCLAW_OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENCLAW_OPENAI_COST_EFFICIENT_MODEL=gpt-5.4-mini
OPENCLAW_OPENAI_HIGH_REASONING_MODEL=gpt-5.5
OPENCLAW_CLOUD_COST_CURRENCY=MXN
OPENCLAW_USD_MXN_RATE=
OPENCLAW_ADAPTIVE_ROUTING_ENABLED=0
OPENCLAW_EXTERNAL_ROUTER_ENABLED=0
OPENCLAW_EXTERNAL_ROUTER_KIND=openrouter
OPENCLAW_EXTERNAL_ROUTER_BASE_URL=
