EDGE_IOT_COMMAND=/usr/bin/env bash -lc "sleep infinity"
EDGE_IOT_WORKDIR=/srv/tesis/workspace/edge
EDGE_IOT_LOG_DIR=/var/log/edge-iot
EDGE_IOT_STATE_DIR=/var/lib/edge-iot
EDGE_IOT_RUNTIME_DIR=/var/lib/edge-iot/runtime
EDGE_IOT_SPOOL_DIR=/srv/tesis/intercambio/edge/spool
EDGE_IOT_HEALTHCHECK_CMD=/srv/tesis/repo/ops/edge/edge-iot-healthcheck.sh
EDGE_IOT_REQUIRES_NETWORK=0
EDGE_IOT_EXTERNAL_CHECK_CMD=true
EDGE_IOT_WATCHDOG_INTERVAL_SEC=120
EDGE_IOT_FAILURE_WINDOW_SEC=900
EDGE_IOT_MAX_CONSECUTIVE_FAILURES=3
EDGE_IOT_SOFT_FAILURE_RESTART_THRESHOLD=2
EDGE_IOT_BACKOFF_SEC=30
EDGE_IOT_QUARANTINE_SEC=1800
EDGE_IOT_HEARTBEAT_INTERVAL_SEC=30
EDGE_IOT_HEARTBEAT_STALE_SEC=180
