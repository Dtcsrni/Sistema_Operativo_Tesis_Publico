OPENCLAW_PORT=18789
OPENCLAW_HOST=0.0.0.0
OPENCLAW_GATEWAY_TOKEN=${OPENCLAW_GATEWAY_TOKEN:-}
OPENCLAW_RUNTIME=docker
OPENCLAW_REPO_ROOT=/app
OPENCLAW_DATA_DIR=/app/runtime/openclaw/state
OPENCLAW_CACHE_DIR=/app/runtime/openclaw/cache
OPENCLAW_LOG_DIR=/app/runtime/openclaw/logs
OPENCLAW_DB_PATH=/app/runtime/openclaw/state/openclaw.db
OPENCLAW_ENV_FILE=/app/config/env/openclaw.env
OPENCLAW_PYTHON_BIN=python3
OPENCLAW_WEB_ENABLED=1
OPENCLAW_SERENA_ENABLED=1
OPENCLAW_SERENA_MODE=required
OPENCLAW_SERENA_TRANSPORT=http
OPENCLAW_SERENA_URL=http://servidor-contexto-serena:8765/mcp
OPENCLAW_SERENA_TIMEOUT_MS=4000
OPENCLAW_SERENA_AUTO_START=1
OPENCLAW_EDGE_INFERENCE_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_TELEGRAM_EDGE_MODEL=qwen3:4b
OPENCLAW_IMAGE_BACKEND=disabled
OPENCLAW_MATRIX_ENABLED=0
OPENCLAW_MATRIX_READY_ON_START=0
OPENCLAW_TELEGRAM_ENABLED=1
OPENCLAW_TELEGRAM_TOKEN=${OPENCLAW_TELEGRAM_TOKEN:-}
OPENCLAW_TELEGRAM_BOT_TOKEN=${OPENCLAW_TELEGRAM_BOT_TOKEN:-}
OPENCLAW_TELEGRAM_CHAT_ID=${OPENCLAW_TELEGRAM_CHAT_ID:-}
OPENCLAW_TELEGRAM_READY_ON_START=1
OPENCLAW_TELEGRAM_READY_MESSAGE="<b>🧬 OpenClaw Edge: Asistente Científico Activado</b>\nConsciencia de sistema cargada. ¿En qué trabajamos hoy, Erick?"
# POLÍTICA DEC-0030: SOBERANÍA LOCAL-FIRST
OPENCLAW_CLOUD_ENABLED="0"
OPENCLAW_CHATGPT_PLUS_ENABLED="0"
OPENCLAW_SDR_ENABLED="1"

# PROACTividad Y APRENDIZAJE
OPENCLAW_SENTINEL_ENABLED="1"
OPENCLAW_PROACTIVE_LEARNING="1"
OPENCLAW_DISCOVERY_NOTIFICATIONS="1"
OPENCLAW_THESIS_NUDGE_DAYS="1"
OPENCLAW_TELEGRAM_POLL_INTERVAL=2
OPENCLAW_TELEGRAM_POLL_INTERVAL_SECONDS=2
OPENCLAW_TELEGRAM_ROLE=primary
OPENCLAW_HERMES_ENABLED="1"
OPENCLAW_BYPASS_SAFE_MODE="1"

# Modo de solo telemetría para Telegram
OPENCLAW_TELEGRAM_TELEMETRY_ONLY=1

# Configuración de Cómputo Pesado (Desktop -> llama.cpp local)
OPENCLAW_DESKTOP_COMPUTE_ENABLED=1
OPENCLAW_DESKTOP_COMPUTE_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_DESKTOP_COMPUTE_MODEL=mistral-nemo:12b
OPENCLAW_DESKTOP_RUNTIME=llamacpp
OPENCLAW_DESKTOP_RUNTIME_BASE_URL=http://inferencia-llamacpp:8080/v1
OPENCLAW_DESKTOP_RUNTIME_MODEL=mistral-nemo:12b
OPENROUTER_API_KEY=${OPENROUTER_API_KEY:-}
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FREE_RPM=20
OPENROUTER_FREE_DAILY_WITHOUT_10USD_CREDITS=50
OPENROUTER_FREE_DAILY_WITH_10USD_CREDITS=1000
OPENCLAW_MISSION_CONTROL_AUTO_EXECUTE=1
OPENCLAW_GEMINI_ENABLED=1
OPENCLAW_GEMINI_MODEL=gemini-1.5-flash
OPENCLAW_GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
OPENCLAW_GEMINI_API_KEY=${OPENCLAW_GEMINI_API_KEY:-}
OPENCLAW_GEMINI_TIMEOUT=120
# Deshabilitar fallback a 127.0.0.1:21435 dentro de Docker
OPENCLAW_LLAMACPP_LOCAL_FALLBACK=0

# Timeouts extendidos para inferencia en CPU (Cold start > 70s)
OPENCLAW_CHAT_HEAVY_TIMEOUT=600
OPENCLAW_CHAT_FACTUAL_TIMEOUT=600
OPENCLAW_CHAT_SIMPLE_TIMEOUT=120

# Activar ruteo adaptativo para usar el PC por defecto si es mejor
OPENCLAW_ADAPTIVE_ROUTING_ENABLED=1

# Serena Bridge
SERENA_BRIDGE_BEARER_TOKEN=${SERENA_BRIDGE_BEARER_TOKEN:-}
