[Unit]
Description=Healthcheck del Sistema Operativo de Tesis
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/srv/tesis/repo
ExecStart=/bin/bash /srv/tesis/repo/ops/actualizacion/healthcheck_tesis.sh
User=tesis
Group=tesis
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
ReadOnlyPaths=/srv/tesis/repo
ReadWritePaths=/var/log/tesis-os
